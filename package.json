{
  "name": "@go-denki/fraft",
  "version": "0.1.0",
  "description": "Dynamically fetch or send API data using JSON/YAML config with a built-in transform pipeline",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "api",
    "fetch",
    "http",
    "yaml",
    "json",
    "config",
    "transform",
    "pipeline"
  ],
  "license": "MIT",
  "peerDependencies": {
    "axios": "^1.6.0 || ^2.0.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.10",
    "axios-mock-adapter": "^2.1.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
